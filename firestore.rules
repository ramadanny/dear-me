rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['username']) &&
        data.username is string && data.username.size() <= 50 &&
        data.get('displayName', '') is string &&
        data.get('age', 0) is number &&
        data.get('height', 0) is number &&
        data.get('weight', 0) is number &&
        data.get('gender', '') is string &&
        data.get('submitTotal', 0) is number &&
        data.get('dateFirstLogin', 0) is number &&
        data.get('dateLastLogin', 0) is number;
    }

    function isValidBmiData(data, userId) {
      return data.keys().hasAll(['userId', 'date', 'age', 'height', 'weight', 'gender', 'activity', 'imt', 'aiSuggestionText']) &&
        data.userId == userId &&
        data.date is number &&
        data.age is number &&
        data.height is number &&
        data.weight is number &&
        data.gender is string && data.gender.size() <= 10 &&
        data.activity is number &&
        data.imt is string && data.imt.size() <= 50 &&
        data.get('stDeviasi', '') is string &&
        data.get('zScore', '') is string &&
        data.get('bbNormalMin', '') is string &&
        data.get('bbNormalMax', '') is string &&
        data.get('bmr', '') is string &&
        data.get('tee', '') is string &&
        data.aiSuggestionText is string && data.aiSuggestionText.size() <= 10000;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName', 'age', 'height', 'weight', 'gender', 'submitTotal', 'dateLastLogin'
        ])
      );
      
      match /bmi_data/{bmiId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(bmiId);
        allow list: if isOwner(userId) && isValidId(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(bmiId) && isValidBmiData(incoming(), userId) &&
          exists(/databases/$(database)/documents/users/$(userId));
        allow update: if false;
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(bmiId);
      }
    }
  }
}
